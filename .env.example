# =============================================================================
# CPT208 Discussion Rehearsal - Stage 2 Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Only OPENAI_API_KEY has no default and must be provided.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Room Cleanup ---
ROOM_CLEANUP_TIMEOUT_MS=30000

# --- LLM Configuration ---
OPENAI_BASEURL=https://zenmux.ai/api/v1
OPENAI_API_KEY=
ROLEPLAY_MODEL=minimax/minimax-m2-her
HINT_MODEL=stepfun/step-3.5-flash
SUMMARY_MODEL=moonshotai/kimi-k2.5

# --- External Services ---
# When running via docker-compose, use service hostnames:
#   WHISPER_BASEURL=http://whisper:8080
#   MEDIAMTX_BASEURL=http://mediamtx:8888
# When running locally:
#   WHISPER_BASEURL=http://localhost:8080
#   MEDIAMTX_BASEURL=http://localhost:8888
WHISPER_BASEURL=http://localhost:8080
MEDIAMTX_BASEURL=http://localhost:8888
